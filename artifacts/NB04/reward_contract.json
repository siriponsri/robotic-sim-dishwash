{
  "version": "2.0",
  "description": "Dense reward for UnitreeG1DishWipe-v1 (custom env v2)",
  "source": "src/envs/dishwipe_env.py :: compute_dense_reward()",
  "terms": {
    "r_clean": {
      "weight": 10.0,
      "formula": "w * delta_clean",
      "sign": "+",
      "range": "[0, w*9]"
    },
    "r_reach": {
      "weight": 0.5,
      "formula": "w * (1 - tanh(5 * dist(palm, plate)))",
      "sign": "+",
      "range": "[0, w]"
    },
    "r_contact": {
      "weight": 1.0,
      "formula": "w * is_contacting",
      "sign": "+",
      "range": "[0, w]"
    },
    "r_sweep": {
      "weight": 0.3,
      "formula": "w * ||centroid_t - centroid_{t-1}||",
      "sign": "+",
      "range": "[0, ~w*0.1]",
      "note": "Encourages lateral movement while in contact"
    },
    "r_time": {
      "weight": 0.01,
      "formula": "-w (constant per step)",
      "sign": "-"
    },
    "r_jerk": {
      "weight": 0.05,
      "formula": "-w * ||a_t - a_{t-1}||^2",
      "sign": "-"
    },
    "r_act": {
      "weight": 0.005,
      "formula": "-w * ||a_t||^2",
      "sign": "-"
    },
    "r_force": {
      "weight": 0.01,
      "formula": "-w * max(0, F_contact - F_soft)",
      "sign": "-",
      "note": "F_contact = force magnitude (L2 norm, not Fz). Magnitude \u2248 Fz for horizontal plate."
    },
    "r_success": {
      "weight": 50.0,
      "formula": "one-shot when cleaned >= 95%",
      "sign": "+"
    }
  },
  "safety": {
    "F_soft": 50.0,
    "F_hard": 200.0,
    "note": "Force thresholds are on magnitude (L2 norm), not normal-axis Fz. Conservative for horizontal plate.",
    "contact_threshold": 0.5,
    "success_clean_ratio": 0.95
  },
  "termination": [
    {
      "reason": "success",
      "condition": "cleaned_ratio >= 0.95"
    },
    {
      "reason": "force_limit",
      "condition": "contact_force > 200.0 N"
    },
    {
      "reason": "timeout",
      "condition": "steps >= max_episode_steps (1000)"
    }
  ]
}